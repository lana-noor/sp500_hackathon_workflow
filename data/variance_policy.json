{
  "policy_name": "EDA Budget Variance Management Policy",
  "policy_reference": "EDA-FIN-POL-003",
  "version": "v2.1",
  "effective_date": "2025-01-01",
  "review_date": "2026-01-01",
  "owner": "Office of Finance & Procurement",
  "approved_by": "Board of Directors",
  "thresholds": {
    "acceptable": {
      "max_variance_pct": 5,
      "description": "Within acceptable tolerance — no action required beyond standard reporting",
      "action": "Record in quarterly report",
      "notification_required": false
    },
    "minor_variance": {
      "min_variance_pct": 5,
      "max_variance_pct": 10,
      "description": "Minor variance requiring departmental justification",
      "action": "Department head must provide written justification within 10 business days",
      "notification_required": true,
      "notify_roles": ["Department Head", "Finance Business Partner"]
    },
    "significant_variance": {
      "min_variance_pct": 10,
      "max_variance_pct": 25,
      "min_variance_aed": 500000,
      "description": "Significant overspend requiring CFO approval",
      "action": "CFO approval required within 5 business days. Reallocation plan must be submitted.",
      "notification_required": true,
      "notify_roles": ["Department Head", "CFO", "Finance Committee"],
      "board_notification": false
    },
    "critical_variance": {
      "min_variance_pct": 25,
      "description": "Critical variance requiring Board notification and emergency review",
      "action": "Immediate Board notification. Emergency budget reallocation review within 2 business days. Spending freeze on non-essential items.",
      "notification_required": true,
      "notify_roles": ["Department Head", "CFO", "Director General", "Board of Directors"],
      "board_notification": true,
      "spending_freeze": true
    },
    "underspend_review": {
      "threshold_pct": 15,
      "description": "Significant underspend may indicate delivery delays or capacity issues",
      "action": "Programme delivery review required. Funds subject to reallocation to overspending departments.",
      "notification_required": true,
      "notify_roles": ["Department Head", "Finance Business Partner", "CFO"]
    }
  },
  "reporting_requirements": {
    "frequency": "Quarterly",
    "submission_deadline_days_after_quarter_end": 30,
    "format": "Markdown report with department-level tables",
    "distribution": ["CFO", "Director General", "Finance Committee", "Department Heads"],
    "board_reporting_frequency": "Semi-annual"
  },
  "reallocation_rules": {
    "max_reallocation_pct_without_board_approval": 10,
    "reallocations_require_cfo_sign_off": true,
    "reallocations_to_new_budget_lines_require_board_approval": true
  },
  "audit_requirements": {
    "internal_audit_threshold_aed": 1000000,
    "external_audit_threshold_aed": 5000000,
    "audit_committee_notification_threshold_pct": 20
  }
}