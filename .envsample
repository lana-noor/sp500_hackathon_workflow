# ── Azure AI Project ──────────────────────────────────────────────────────────
AZURE_AI_PROJECT_ENDPOINT=https://<<your-foundry-project-resource>>.services.ai.azure.com/api/projects/agents-resource-foundry
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-4o

# ── Azure OpenAI ──────────────────────────────────────────────────────────────
AZURE_OPENAI_API_VERSION=2025-03-01-preview

# ── Workflow Settings ─────────────────────────────────────────────────────────
OUTPUT_DIR=./output 

# =============================================================================
# S&P 500 RESEARCH WORKFLOW (portfolio_risk_workflow.py)
# =============================================================================

# ── Data location ─────────────────────────────────────────────────────────────
# Path to the folder containing tickerlist.csv, prices.csv, returns.csv
SP500_DATA_DIR=./sp500_sample_data

# ── Agent 1 — Query Planner (FoundryChatClient — no portal agent needed) ──────
#    Uses AZURE_AI_PROJECT_ENDPOINT + AZURE_AI_MODEL_DEPLOYMENT_NAME above

# ── Agent 2 — Quantitative Analyst (FoundryAgent + Code Interpreter) ──────────
#    In Foundry portal:
#      1. Create a new agent
#      2. Enable Code Interpreter tool
#      3. Upload and attach: tickerlist.csv, prices.csv, returns.csv from sp500_sample_data/
#      4. Set system prompt from: prompts/quantitative_analyst_agent.txt
QUANT_AGENT_NAME=SP500QuantAgent
QUANT_AGENT_VERSION=1

# ── Agent 3 — Search Query Expander (FoundryChatClient — no portal agent needed)
#    Uses AZURE_AI_PROJECT_ENDPOINT + AZURE_AI_MODEL_DEPLOYMENT_NAME above

# ── Agent 4 — Web Researcher (FoundryChatClient + Tavily, called per query) ───
#    No portal deployment needed.
#    Get a free Tavily API key at: https://tavily.com
#    If left blank, Agent 4 will skip web searches and return empty evidence.
TAVILY_API_KEY=tvly-your-key-here

# ── Agent 5 — Synthesizer (FoundryChatClient — no portal deployment needed) ───
#    Uses AZURE_AI_PROJECT_ENDPOINT + AZURE_AI_MODEL_DEPLOYMENT_NAME above
